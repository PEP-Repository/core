{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowJs": true,
    "checkJs": true,
    // Type checking
    "strict": true,
    "strictNullChecks": false,
    // Output
    "noEmit": true,
    // CLI
    "pretty": true
  },
  "include": ["./**/*.mjs", "./web-apis.d.ts"],
  "exclude": ["./dist/"]
}
