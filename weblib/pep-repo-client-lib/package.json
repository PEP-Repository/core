{
  "name": "pep-repo-client-lib",
  "version": "0.0.0",
  "description": "PEP repository web client library",
  "type": "module",
  "exports": {
    ".": "./dist/pep.mjs",
    "./utils": "./dist/utils.mjs"
  },
  "typesVersions": {
    "*": {
      "*": ["./dist/*"]
    }
  },
  "// scripts.prepare": "Transitive local dependencies are not automatically installed: https://docs.npmjs.com/cli/v11/configuring-npm/package-json#local-paths",
  "scripts": {
    "prepare": "cd ../pep-repo-client-wasm && npm install",
    "prepack": "tsc",
    "types:check": "tsc --noEmit",
    "build": "tsc",
    "build:watch": "tsc --watch --preserveWatchOutput",
    "test": "mocha"
  },
  "files": [
    "./dist/**/*.mjs",
    "./dist/**/*.d.mts"
  ],
  "repository": {
    "type": "git",
    "url": "https://gitlab.pep.cs.ru.nl/pep/core.git"
  },
  "dependencies": {
    "pep-repo-client-wasm": "file:../pep-repo-client-wasm"
  },
  "bundleDependencies": [
    "pep-repo-client-wasm"
  ],
  "devDependencies": {
    "@types/chai": "^5.2.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.0.13",
    "chai": "^5.2.1",
    "mocha": "^11.7.1",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
