{
  "debug-level": 1,
  "skip-analysis-in-path": [
	  ".*rxcpp.*",
    ".*/usr/include/c\\+\\+/.*",
    ".*\\Tools\\MSVC.*"
  ],
  "report-suppress-errors": [
    "PULSE_CONST_REFABLE",
    "PULSE_UNNECESSARY_COPY_INTERMEDIATE",
    "PULSE_UNNECESSARY_COPY_ASSIGNMENT",
    "PULSE_UNNECESSARY_COPY",
    "PULSE_READONLY_SHARED_PTR_PARAM",
    "PULSE_UNNECESSARY_COPY_OPTIONAL",
    "OPTIONAL_EMPTY_ACCESS",
    "DEAD_STORE",
    "PULSE_UNNECESSARY_COPY_ASSIGNMENT_CONST"
  ],
  "report-block-list-spec": [
    {
      "bug_type": "USE_AFTER_DELETE",
      "file": "cpp/pep/rsk/RskRecipient.hpp",
      "procedure_name": "~SkRecipient",
      "comment": "This is a fp because..."
    }
  ]
}